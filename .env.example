NODE_ENV=development
SERVERPORT=8080

# JWT Config
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=30d

# Database Connection (PostgreSQL)
DB=your_database_name
USERNAMES=your_database_username
HOST=your_database_host
DB_PASSWORDS=your_database_password
DBPORT=5432

# Azure Blob Storage (For WhatsApp Image Uploads)
AZURE_STORAGE_CONNECTION_STRING=your_azure_storage_connection_string
AZURE_ADVISORY_CONTAINER=your_azure_advisory_container_name
